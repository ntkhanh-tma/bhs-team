# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit it.

# Google Apps Script gateway — the ONLY thing that touches the sheet.
# Deploy apps-script/Code.gs: Extensions → Apps Script → Deploy as Web App
#   Execute as: Me  |  Who has access: Anyone
# Paste the deployment /exec URL below.
VACATION_API_URL=your_apps_script_web_app_url_here

# Shared secret sent with every gateway request. Must exactly match the
# APP_SECRET script property you set in the Apps Script project.
# Generate a long random value (e.g. `openssl rand -hex 32`).
GATEWAY_SECRET=your_gateway_shared_secret_here

# API Ninjas (https://api-ninjas.com) — daily riddle widget
API_NINJAS_KEY=your_api_ninjas_key_here
