# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit it.

# Google Sheets API (read-only: Members, Holidays, Vacation-Plan)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Apps Script Web App URL (vacation write proxy)
# Deploy apps-script/Code.gs: Extensions → Apps Script → Deploy as Web App
#   Execute as: Me  |  Who has access: Anyone
# Paste the deployment URL below.
VACATION_API_URL=your_apps_script_web_app_url_here
