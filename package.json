{
  "name": "vacation-planner",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/setup-env.js",
    "start": "ng serve",
    "prebuild": "node scripts/setup-env.js",
    "build": "ng build",
    "build:prod": "node scripts/setup-env.js && ng build --configuration=production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "setup-env": "node scripts/setup-env.js"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.1.8",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.1.0",
    "@angular/compiler": "^20.1.0",
    "@angular/core": "^20.1.0",
    "@angular/forms": "^20.1.0",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.1.0",
    "@angular/router": "^20.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.1.4",
    "@angular/cli": "^20.1.4",
    "@angular/compiler-cli": "^20.1.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/jasmine": "~5.1.0",
    "autoprefixer": "^10.5.2",
    "jasmine-core": "~5.8.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2"
  }
}
